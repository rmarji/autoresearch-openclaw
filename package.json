{
  "name": "autoresearch-openclaw",
  "version": "1.0.0",
  "description": "Autonomous optimization loop for any text asset with a scalar metric. Karpathy's autoresearch, packaged for OpenClaw.",
  "type": "module",
  "bin": {
    "autoresearch": "./bin/autoresearch.js"
  },
  "main": "./src/cli/index.js",
  "scripts": {
    "start": "node bin/autoresearch.js",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "boxen": "^8.0.0",
    "chalk": "^5.0.0",
    "cli-table3": "^0.6.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.0.0",
    "inquirer": "^9.0.0",
    "ora": "^8.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "openclaw",
    "autoresearch",
    "optimization",
    "karpathy",
    "ai-agent",
    "autonomous",
    "prompt-optimization",
    "machine-learning"
  ],
  "author": "Rayo Marji",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rmarji/autoresearch-openclaw"
  },
  "homepage": "https://github.com/rmarji/autoresearch-openclaw"
}
